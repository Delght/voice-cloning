# Anything-LLM connection
# Mac/Windows Docker: host.docker.internal resolves to the host machine automatically.
# Linux Docker: set to the host machine's actual IP (e.g. http://192.168.1.x:3001)
#   or use the docker-compose extra_hosts entry which maps host.docker.internal:host-gateway.
ANYTHINGLLM_BASE_URL=http://host.docker.internal:3001
ANYTHINGLLM_API_KEY=your_api_key_here   # required; from Anything-LLM settings
ANYTHINGLLM_WORKSPACE_SLUG=voice-assistant

# TTS: fish | vieneu | fish,vieneu. Unset in process env also defaults to fish in services/tts/app.py.
# docker-compose.yml sets TTS_ENGINES=vieneu on the tts container only (that image has no fish-speech).
TTS_ENGINES=fish

# Device: cuda on Nvidia cloud, cpu on Mac (faster-whisper/ctranslate2 has no MPS)
STT_DEVICE=cpu
STT_MODEL_SIZE=large-v3

# VieNeu backbone always runs on CPU (llama-cpp-python limitation).
# Codec (NeuCodec/PyTorch) can use cuda on Nvidia GPU.
VIENEU_DEVICE=cpu

# External repos (override if not under ~)
FISH_SPEECH_ROOT=~/fish-speech
FISH_MODEL_DIR=models/fish-speech-1.5
APPLIO_ROOT=~/applio
RVC_MODELS_DIR=models/rvc

# Gateway -> microservices (seconds). Long fish-speech: keep high. Gradio TTS/chat: optional UI_TTS_TIMEOUT.
GATEWAY_TIMEOUT=900
# UI_TTS_TIMEOUT=900

# Internal URLs (gateway); change if you remap ports
STT_URL=http://stt:8001
TTS_URL=http://tts:8002
RVC_URL=http://rvc:8003
LLM_URL=http://llm:8004
VBV_URL=http://vbv:8005

# UI to gateway
# When running UI in Docker, gateway is accessible via service name
GATEWAY_URL=http://gateway:8000

# Fish ref for Voice Chat and POST /chat (UI upload or paths below)
# Default ref: audio/reference/phuong_anh.wav. Transcript for that clip (STT-generated): audio/reference/phuong_anh.transcript.txt
# VOICE_CHAT_FISH_REF_AUDIO=/absolute/path/to/reference.wav
# VOICE_CHAT_FISH_REF_TEXT=paste transcript here or use: export VOICE_CHAT_FISH_REF_TEXT="$(cat audio/reference/phuong_anh.transcript.txt)"
# CHAT_FISH_REF_AUDIO=/absolute/path/to/reference.wav   # /chat only; else uses VOICE_* above
# CHAT_FISH_REF_TEXT=transcript
